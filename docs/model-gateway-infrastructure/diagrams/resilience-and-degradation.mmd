flowchart TD
  A["模型请求<br/>deadline + retry budget"] --> L{"预算与分层限流"}
  L -- 不通过 --> Q["排队 / 拒绝<br/>带 retry-after"]
  L -- 通过 --> C{"安全缓存命中？"}
  C -- 是 --> R["返回命中证据"]
  C -- 否 --> H{"端点健康且能力匹配？"}
  H -- 是 --> P["派发调用"]
  H -- 否 --> F{"候选仍满足<br/>能力 / 风险 / 区域？"}
  P --> O{"调用结果"}
  O -- 成功 --> R
  O -- 429或明确失败 --> F
  O -- 部分输出或未知 --> U["标记 incomplete / unknown<br/>返回编排决策"]
  F -- 是 --> P
  F -- 否 --> E["类型化失败<br/>fail closed"]
